# --- Rails (backend/) ---
/backend/.bundle
/backend/.env*
/backend/log/*
/backend/tmp/*
!/backend/log/.keep
!/backend/tmp/.keep
/backend/tmp/pids/*
!/backend/tmp/pids/
!/backend/tmp/pids/.keep
/backend/storage/*
!/backend/storage/.keep
/backend/tmp/storage/*
!/backend/tmp/storage/
!/backend/tmp/storage/.keep
/backend/config/master.key

# --- Node / Vite (frontend/) ---
/frontend/node_modules
/frontend/dist
/frontend/.env*
/frontend/*.local

# --- Editor / OS (global-ish, safe at root) ---
.DS_Store
*.swp